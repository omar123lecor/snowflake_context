          "sample_rows": [
            {
              "REVIEW_ID": "6e43b9a6a5985b9eb501a26d9f6c88ed",
              "LISTING_ID": 7571301,
              "REVIEW_DATE": "2021-10-10T00:00:00",
              "REVIEW_TEXT": "Lovely apartment in a nice part of Berlin only a short distance from the centre via a nearby tram. Very friendly and accommodating host. Hope to stay there again at some point.",
              "REVIEWER_NAME": "Lyndon",
              "REVIEW_SENTIMENT": "positive"
            },
            {
              "REVIEW_ID": "96a7da264000efd3666d3c5cd21539f3",
              "LISTING_ID": 7574664,
              "REVIEW_DATE": "2019-11-11T00:00:00",
              "REVIEW_TEXT": "Dominique and her family are lovely hosts. Area is super quiet and near pubs, clubs, restaurants and local transport such as taxis, trams and underground trains. brbrApartment is gorgeous and super clean with shower and bathroom across from your room. brbrWill definitely come back and highly recommend Dominiques home for travelers .",
              "REVIEWER_NAME": "Ryan",
              "REVIEW_SENTIMENT": "positive"
            },
            {
              "REVIEW_ID": "4e2eed61ab44a26c33d7c028a7ea8478",
              "LISTING_ID": 7574664,
              "REVIEW_DATE": "2021-08-06T00:00:00",
              "REVIEW_TEXT": "Beautiful spacious modern apartment. A short walk to transportation and many areas of interest.",
              "REVIEWER_NAME": "Morris",
              "REVIEW_SENTIMENT": "positive"
            },
            {
              "REVIEW_ID": "9dfb89e6338c34d335709c0ef9868f2c",
              "LISTING_ID": 7575270,
              "REVIEW_DATE": "2017-07-22T00:00:00",
              "REVIEW_TEXT": "Frankies flat was absolutely wonderful. The location was perfect for us, very easy to get to from the airport and close to pretty much everything we wanted to experience in Berlin. brFrankie and their (Hidden by Airbnb) were all incredibly welcoming and made us feel right at home from arrival.brSpecial thank you to Smila the cat who was undoubtedly the highlight of the entire trip.",
              "REVIEWER_NAME": "Freddie",
              "REVIEW_SENTIMENT": "positive"
            },
            {
              "REVIEW_ID": "9dbe4c980659dd46f287f0e6b5c39adc",
              "LISTING_ID": 7577046,
              "REVIEW_DATE": "2019-03-04T00:00:00",
              "REVIEW_TEXT": "Tolle Unterkunft f\u00fcr g\u00fcnstigen Preis. Und Gastgebern sind sehr nett.",
              "REVIEWER_NAME": "Alexandr",
              "REVIEW_SENTIMENT": "neutral"
            }
          ]
